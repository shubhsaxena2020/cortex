# Dependencies
node_modules/

# Build output
dist/
release/
*.tsbuildinfo
# tsc --build can emit .d.ts/.js into src/ — those are artifacts, never source.
src/**/*.d.ts
src/**/*.js

# Local Electron data
.cortex-shots/

# Env / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp

# Test / coverage
coverage/
.nyc_output/

# Misc
*.pid
*.seed
